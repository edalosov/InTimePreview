# Get this from Vercel dashboard → Storage → your Blob store → ".env.local" tab
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Choose any password you want for the admin page
ADMIN_PASSWORD=your_secret_password_here

# OpenSea NFT pricing (optional — prices are hidden if these are not set)
# API key from https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key_here
# The "slug" of your collection on OpenSea (visible in the collection URL)
OPENSEA_COLLECTION_SLUG=your-collection-slug
